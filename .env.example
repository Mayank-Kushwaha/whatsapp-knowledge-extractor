# WhatsApp Knowledge Extractor — Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit the actual .env file — it is gitignored.

# === LLM Configuration ===
GEMINI_API_KEY=                        # https://aistudio.google.com/app/apikey (free)
LLM_PROVIDER=gemini                    # "gemini" or "ollama"
OLLAMA_BASE_URL=http://localhost:11434 # only needed if LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3                    # only needed if LLM_PROVIDER=ollama

# === Paths (defaults work out of the box for local dev) ===
DATA_DIR=./data
MEDIA_DIR=./data/media
DB_PATH=./data/knowledge.db

# === Server ===
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === CORS — Production ===
# Set this to your Vercel frontend URL when deploying to Render.
# Supports comma-separated values for multiple origins.
# Example: FRONTEND_ORIGIN=https://your-app.vercel.app
# Leave unset for local dev (localhost:3000 is always allowed).
FRONTEND_ORIGIN=

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
