# WhatsApp Knowledge Extractor — Environment Variables
# Copy this file to .env and fill in your values

# === LLM Configuration ===
GEMINI_API_KEY=
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# === Paths ===
DATA_DIR=./data
MEDIA_DIR=./data/media
DB_PATH=./data/knowledge.db

# === Server ===
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
